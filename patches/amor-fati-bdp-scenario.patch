@@ -0,0 +1,77 @@
+package com.boombustgroup.amorfati
+
+import com.boombustgroup.amorfati.types.*
+import org.scalatest.flatspec.AnyFlatSpec
+import org.scalatest.matchers.should.Matchers
+import zio.{Chunk, Exit, Runtime, Unsafe}
+
+class MainSpec extends AnyFlatSpec with Matchers:
+
+  "Main CLI parser" should "keep baseline parameters when BDP is not provided" in {
+    val cli = parse("10", "baseline", "--duration", "60", "--run-id", "baseline-60m-10s")
+
+    cli.runConfig.nSeeds shouldBe 10
+    cli.runConfig.outputPrefix shouldBe "baseline"
+    cli.runConfig.runDurationMonths shouldBe 60
+    cli.runConfig.runId shouldBe "baseline-60m-10s"
+    cli.basicIncomeMonthly shouldBe PLN.Zero
+    cli.basicIncomeReservationWagePassThrough shouldBe Share.Zero
+    cli.simParams.fiscal.basicIncomeMonthly shouldBe PLN.Zero
+    cli.simParams.fiscal.basicIncomeReservationWagePassThrough shouldBe Share.Zero
+  }
+
+  it should "apply the BDP parameter to fiscal transfers and reservation wages" in {
+    val cli = parse("10", "bdp-2000", "--duration", "60", "--run-id", "bdp-2000-60m-10s", "--bdp", "2000")
+
+    cli.basicIncomeMonthly shouldBe PLN(2000)
+    cli.basicIncomeReservationWagePassThrough shouldBe Share.decimal(50, 2)
+    cli.simParams.fiscal.basicIncomeMonthly shouldBe PLN(2000)
+    cli.simParams.fiscal.basicIncomeReservationWagePassThrough shouldBe Share.decimal(50, 2)
+  }
+
+  it should "allow overriding the BDP reservation-wage pass-through" in {
+    val cli = parse(
+      "10",
+      "bdp-2000-lambda-075",
+      "--duration",
+      "60",
+      "--run-id",
+      "bdp-2000-lambda-075-60m-10s",
+      "--bdp",
+      "2000",
+      "--bdp-lambda",
+      "0.75",
+    )
+
+    cli.basicIncomeMonthly shouldBe PLN(2000)
+    cli.basicIncomeReservationWagePassThrough shouldBe Share.decimal(75, 2)
+    cli.simParams.fiscal.basicIncomeMonthly shouldBe PLN(2000)
+    cli.simParams.fiscal.basicIncomeReservationWagePassThrough shouldBe Share.decimal(75, 2)
+  }
+
+  it should "keep zero baseline pass-through even when lambda is provided without BDP" in {
+    val cli = parse("10", "baseline", "--bdp", "0", "--bdp-lambda", "1.0")
+
+    cli.basicIncomeMonthly shouldBe PLN.Zero
+    cli.basicIncomeReservationWagePassThrough shouldBe Share.Zero
+    cli.simParams.fiscal.basicIncomeMonthly shouldBe PLN.Zero
+    cli.simParams.fiscal.basicIncomeReservationWagePassThrough shouldBe Share.Zero
+  }
+
+  it should "reject BDP lambda values outside the share range" in {
+    parseFailure("10", "bdp-2000", "--bdp", "2000", "--bdp-lambda", "1.25").getMessage should include("--bdp-lambda must be in [0,1]")
+  }
+
+  private def parse(args: String*): Main.CliConfig =
+    Unsafe.unsafe: unsafe =>
+      given Unsafe = unsafe
+      Runtime.default.unsafe.run(Main.parseArgs(Chunk.fromIterable(args))).getOrThrowFiberFailure()
+
+  private def parseFailure(args: String*): IllegalArgumentException =
+    Unsafe.unsafe: unsafe =>
+      given Unsafe = unsafe
+      Runtime.default.unsafe.run(Main.parseArgs(Chunk.fromIterable(args))) match
+        case Exit.Success(_)     => fail("expected parse failure")
+        case Exit.Failure(cause) => cause.failureOption.getOrElse(fail("expected typed parse failure"))
+
+end MainSpec
